        },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count[1m])) > 0",
          "legendFormat": "{{uri}} ({{status}})"
        }
      ],
      "title": "Taxa de Requisições por Rota HTTP",
      "type": "timeseries"
    },
